<view class="success-container flex-center">
  <view class="success-card">
    <view class="check-circle">✓</view>
    <text class="success-title">预约成功</text>
    <text class="order-no">订单号：{{orderNo}}</text>
    <text class="success-tip">门店将尽快确认您的预约，请耐心等待</text>
    <button class="btn-primary mt-24" style="width:100%" bindtap="goToOrder">查看订单</button>
    <button class="btn-outline mt-24" style="width:100%" bindtap="goHome">返回首页</button>
  </view>
</view>
