.success-container { min-height: 100vh; padding: 48rpx; }
.success-card { text-align: center; width: 100%; }
.check-circle {
  width: 120rpx; height: 120rpx; border-radius: 50%; background: var(--success);
  color: #fff; font-size: 60rpx; display: flex; align-items: center; justify-content: center;
  margin: 80rpx auto 32rpx;
}
.success-title { font-size: 40rpx; font-weight: 700; color: var(--text); display: block; }
.order-no { font-size: 28rpx; color: var(--text-secondary); display: block; margin-top: 16rpx; }
.success-tip { font-size: 24rpx; color: var(--text-muted); display: block; margin-top: 12rpx; }
