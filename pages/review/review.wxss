.card-title { font-size: 28rpx; font-weight: 600; color: var(--text); margin-bottom: 16rpx; display: block; }
.stars { gap: 12rpx; }
.star { font-size: 60rpx; color: #E0E0E0; }
.star.active { color: #FAAD14; }
.review-textarea { width: 100%; height: 200rpx; font-size: 26rpx; padding: 16rpx; background: #F5F5F5; border-radius: 12rpx; }
