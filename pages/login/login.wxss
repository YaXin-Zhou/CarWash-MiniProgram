.login-container {
  min-height: 100vh; display: flex; align-items: center; justify-content: center;
  background: linear-gradient(135deg, #1677FF, #69B1FF);
}
.login-card {
  background: #fff; border-radius: var(--radius-lg); padding: 80rpx 60rpx;
  margin: 48rpx; text-align: center; width: 100%;
}
.login-logo { font-size: 100rpx; margin-bottom: 24rpx; }
.login-title { font-size: 44rpx; font-weight: 700; color: var(--text); display: block; }
.login-desc { font-size: 26rpx; color: var(--text-muted); display: block; margin-top: 12rpx; }
.login-btn {
  margin-top: 60rpx; background: var(--primary); color: #fff; border-radius: 44rpx;
  font-size: 32rpx; padding: 20rpx 0; border: none;
}
.login-input {
  width: 100%; padding: 24rpx 28rpx; margin-top: 24rpx;
  background: #F5F5F5; border-radius: 16rpx; font-size: 28rpx;
  text-align: left; box-sizing: border-box;
}
.login-tip { font-size: 22rpx; color: var(--text-muted); display: block; margin-top: 24rpx; }
.login-tip:active { color: var(--primary); }
