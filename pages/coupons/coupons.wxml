<view class="container">
  <navigation-bar title="我的优惠券"></navigation-bar>

  <scroll-view scroll-x class="tab-scroll">
    <text
      wx:for="{{tabs}}" wx:key="key"
      class="tab-item {{activeTab === item.key ? 'active' : ''}}"
      bindtap="switchTab" data-key="{{item.key}}"
    >{{item.label}}</text>
  </scroll-view>

  <view wx:if="{{coupons.length === 0}}" class="empty-state">
    <text class="empty-icon">🎫</text>
    <text class="empty-text">暂无优惠券</text>
  </view>

  <view class="px-24" wx:if="{{coupons.length > 0}}">
    <view
      class="coupon-card card flex"
      wx:for="{{coupons}}" wx:key="id"
      wx:if="{{item.status === activeTab}}"
    >
      <view class="coupon-left-info">
        <text class="c-value">{{item.type === 'percent' ? item.discount_value + '%' : '¥' + item.discount_value}}</text>
        <text class="c-condition">满{{item.min_amount}}可用</text>
      </view>
      <view class="flex-1">
        <text class="c-name">{{item.name}}</text>
        <text class="c-expire">有效期至 {{item.expire_time}}</text>
      </view>
    </view>
  </view>
</view>
