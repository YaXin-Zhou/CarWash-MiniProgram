.tab-scroll {
  background: var(--white); white-space: nowrap; padding: 16rpx 24rpx;
  border-bottom: 1rpx solid var(--border);
}
.tab-item { display: inline-block; font-size: 26rpx; color: var(--text-secondary); padding: 10rpx 28rpx; }
.tab-item.active { color: var(--primary); font-weight: 600; }

.empty-state { text-align: center; padding: 120rpx 0; }
.empty-icon { font-size: 80rpx; display: block; }
.empty-text { font-size: 28rpx; color: var(--text-muted); display: block; margin-top: 16rpx; }

.coupon-card { margin: 16rpx 0; }
.coupon-left-info {
  width: 160rpx; text-align: center; border-right: 2rpx dashed var(--border);
  padding-right: 24rpx; margin-right: 24rpx;
}
.c-value { font-size: 44rpx; font-weight: 700; color: var(--danger); }
.c-condition { font-size: 22rpx; color: var(--text-muted); display: block; margin-top: 4rpx; }
.c-name { font-size: 28rpx; font-weight: 600; color: var(--text); display: block; }
.c-expire { font-size: 22rpx; color: var(--text-muted); display: block; margin-top: 8rpx; }
