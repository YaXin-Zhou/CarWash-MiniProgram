<view class="container">
  <navigation-bar title="{{isAdmin ? '订单管理' : '服务项目'}}"></navigation-bar>

  <!-- ========== 管理员：订单管理 ========== -->
  <block wx:if="{{isAdmin}}">
    <view class="search-bar">
      <input placeholder="搜索订单号/用户" bindinput="onSearchInput" bindconfirm="search" class="s-input" />
    </view>
    <scroll-view scroll-x class="status-scroll">
      <text
        wx:for="{{statusTabs}}" wx:key="key"
        class="s-tab {{activeStatus === item.key ? 'active' : ''}}"
        bindtap="switchStatus" data-key="{{item.key}}"
      >{{item.label}}</text>
    </scroll-view>
    <view class="order-list">
      <view class="o-card" wx:for="{{orders}}" wx:key="id">
        <view class="flex-between">
          <view>
            <text class="o-no">{{item.order_no}}</text>
            <text class="o-user">{{item.nickname}}</text>
          </view>
          <text class="o-status" style="color:{{util.getOrderStatusColor(item.status)}}">{{util.getOrderStatusText(item.status)}}</text>
        </view>
        <view class="flex-between mt-12">
          <text class="o-info">{{item.service_name}} · {{item.store_name}}</text>
          <text class="o-amt">¥{{item.amount}}</text>
        </view>
        <text class="o-time">{{item.appoint_date}} {{item.appoint_time}}</text>

        <view class="o-actions">
          <button wx:if="{{item.status === 'pending'}}" class="btn-ok" data-id="{{item.id}}" data-status="confirmed" bindtap="updateStatus">确认接单</button>
          <button wx:if="{{item.status === 'pending'}}" class="btn-cxl" data-id="{{item.id}}" data-status="cancelled" bindtap="updateStatus">取消</button>
          <button wx:if="{{item.status === 'confirmed'}}" class="btn-ok" data-id="{{item.id}}" data-status="in_progress" bindtap="updateStatus">开始服务</button>
          <button wx:if="{{item.status === 'in_progress'}}" class="btn-ok" data-id="{{item.id}}" data-status="completed" bindtap="updateStatus">完成服务</button>
        </view>
      </view>
      <view wx:if="{{orders.length === 0}}" class="empty-hint">暂无订单</view>
    </view>
  </block>

  <!-- ========== 普通用户：服务列表 ========== -->
  <block wx:else>
    <scroll-view scroll-x class="cat-tabs">
      <text
        wx:for="{{categories}}" wx:key="*this"
        class="cat-tab {{activeCategory === item ? 'active' : ''}}"
        bindtap="switchCategory" data-cat="{{item}}"
      >{{item}}</text>
    </scroll-view>
    <view class="service-list px-24">
      <view class="service-card card flex" wx:for="{{services}}" wx:key="id" wx:if="{{activeCategory === item.category}}" bindtap="goToDetail" data-id="{{item.id}}">
        <view class="s-icon">{{item.icon}}</view>
        <view class="flex-1">
          <view class="flex-between">
            <text class="s-name">{{item.name}}</text>
            <text class="s-price">¥{{item.price}}</text>
          </view>
          <text class="s-desc">{{item.description}}</text>
          <view class="flex-between mt-16">
            <text class="s-duration">约{{item.duration}}分钟</text>
            <text class="s-original" wx:if="{{item.original_price > item.price}}">¥{{item.original_price}}</text>
          </view>
        </view>
      </view>
    </view>
  </block>
</view>
