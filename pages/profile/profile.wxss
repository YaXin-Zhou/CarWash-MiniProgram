.profile-header {
  background: linear-gradient(135deg, #1677FF, #69B1FF);
  padding: 48rpx 32rpx 40rpx;
}
.avatar {
  width: 120rpx; height: 120rpx; border-radius: 50%; background: rgba(255,255,255,0.3);
  font-size: 56rpx; margin-right: 24rpx; overflow: hidden;
}
.avatar image { width: 100%; height: 100%; }
.nickname { font-size: 36rpx; color: #fff; font-weight: 600; display: block; }
.phone { font-size: 26rpx; color: rgba(255,255,255,0.8); display: block; margin-top: 8rpx; }

.stats-card { margin: -30rpx 24rpx 0; position: relative; }
.stat-item { flex: 1; text-align: center; }
.stat-num { font-size: 40rpx; font-weight: 700; color: var(--text); display: block; }
.stat-label { font-size: 24rpx; color: var(--text-muted); display: block; margin-top: 4rpx; }

.menu-section { background: var(--white); }
.menu-item {
  padding: 28rpx 32rpx; border-bottom: 1rpx solid var(--border);
  font-size: 30rpx; color: var(--text);
}
.menu-icon { margin-right: 16rpx; font-size: 36rpx; }
.menu-arrow { color: var(--text-muted); }

.profile-header.admin-style { background: linear-gradient(135deg, #001529, #1677FF); }
.role-tag {
  display: inline-block; font-size: 20rpx; color: #FFD666;
  background: rgba(255,214,102,0.2); border: 1rpx solid #FFD666;
  border-radius: 6rpx; padding: 2rpx 12rpx; margin-top: 6rpx;
}
.admin-stat-grid {
  display: grid; grid-template-columns: 1fr 1fr 1fr 1fr;
  background: #fff; margin: -20rpx 16rpx 0; border-radius: var(--radius);
  padding: 24rpx 0; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.a-stat { text-align: center; }
.a-num { font-size: 32rpx; font-weight: 700; color: var(--primary); display: block; }
.a-label { font-size: 20rpx; color: var(--text-muted); display: block; margin-top: 4rpx; }

.divider { text-align: center; padding: 24rpx 0 8rpx; }
.divider-text { font-size: 24rpx; color: var(--text-muted); }
