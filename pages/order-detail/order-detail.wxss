.status-header {
  height: 180rpx; background: linear-gradient(135deg, #E6F4FF, #BAE0FF);
}
.status-text { font-size: 40rpx; font-weight: 700; }

.card-title { font-size: 28rpx; font-weight: 600; color: var(--text); margin-bottom: 16rpx; display: block; }
.info-row { padding: 12rpx 0; font-size: 26rpx; color: var(--text-secondary); }
.link { color: var(--primary); }
.price { color: var(--danger); font-weight: 700; font-size: 30rpx; }

.timeline { padding: 8rpx 0; }
.timeline-item { display: flex; align-items: flex-start; margin-bottom: 24rpx; }
.timeline-dot {
  width: 44rpx; height: 44rpx; border-radius: 50%; background: #E0E0E0;
  display: flex; align-items: center; justify-content: center;
  font-size: 24rpx; color: #fff; margin-right: 16rpx; flex-shrink: 0;
}
.timeline-dot.done { background: var(--primary); }
.timeline-title { font-size: 28rpx; color: var(--text); display: block; }
.timeline-time { font-size: 22rpx; color: var(--text-muted); display: block; margin-top: 4rpx; }

.stars { margin-bottom: 12rpx; }
.star { font-size: 40rpx; color: #E0E0E0; margin-right: 8rpx; }
.star.active { color: #FAAD14; }
.review-content { font-size: 26rpx; color: var(--text-secondary); line-height: 1.5; }

.bottom-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: var(--white); padding: 20rpx 32rpx;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.05);
}
