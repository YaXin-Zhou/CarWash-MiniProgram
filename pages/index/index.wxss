/* ---- Admin ---- */
.a-header {
  background: linear-gradient(135deg, #001529, #1677FF);
  padding: 44rpx 32rpx 36rpx;
}
.a-greeting { font-size: 40rpx; font-weight: 700; color: #fff; display: block; }
.a-date { font-size: 24rpx; color: rgba(255,255,255,0.7); display: block; margin-top: 6rpx; }

.a-stats-grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: 12rpx;
  padding: 0 24rpx; margin-top: -16rpx;
}
.a-stat-card {
  background: #fff; border-radius: var(--radius); padding: 24rpx;
  text-align: center; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.a-stat-num { font-size: 36rpx; font-weight: 700; color: var(--primary); display: block; }
.a-stat-label { font-size: 22rpx; color: var(--text-muted); display: block; margin-top: 4rpx; }

.a-tabs { background: #fff; padding: 16rpx 24rpx; margin-top: 16rpx; gap: 12rpx; }
.a-tab { font-size: 26rpx; color: var(--text-secondary); padding: 10rpx 24rpx; border-radius: 32rpx; background: #F5F5F5; }
.a-tab.active { background: var(--primary); color: #fff; }

.a-order-list { padding-bottom: 40rpx; }
.a-order {
  background: #fff; border-radius: var(--radius); margin-top: 16rpx;
  padding: 24rpx; box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.03);
}
.a-o-no { font-size: 22rpx; color: var(--text-muted); }
.a-o-status { font-size: 26rpx; font-weight: 600; }
.a-o-info { font-size: 28rpx; color: var(--text); font-weight: 500; }
.a-o-amount { font-size: 30rpx; color: var(--danger); font-weight: 600; }
.a-o-user { font-size: 22rpx; color: var(--text-muted); display: block; margin-top: 8rpx; }

.a-actions { display: flex; gap: 16rpx; margin-top: 20rpx; }
.a-actions button { flex: 1; border-radius: 32rpx; font-size: 26rpx; padding: 14rpx 0; border: none; }
.a-btn-ok { background: var(--primary); color: #fff; }
.a-btn-no { background: #F5F5F5; color: var(--text-secondary); }
.empty-hint { text-align: center; padding: 60rpx 0; font-size: 26rpx; color: var(--text-muted); }

/* ---- User ---- */
.banner { height: 280rpx; margin: 16rpx 24rpx; }
.banner-item {
  height: 280rpx; border-radius: var(--radius-lg);
  display: flex; align-items: center; justify-content: center; overflow: hidden;
}
.banner-img { width: 100%; height: 100%; border-radius: var(--radius-lg); }
.banner-text { color: #fff; font-size: 40rpx; font-weight: 700; }

.section { margin-top: 24rpx; }
.section-title { font-size: 32rpx; font-weight: 600; color: var(--text); margin-bottom: 16rpx; padding: 0 24rpx; }
.link { font-size: 26rpx; color: var(--text-muted); }

.h-scroll { white-space: nowrap; padding: 0 24rpx; }
.service-item {
  display: inline-flex; flex-direction: column; align-items: center;
  background: var(--white); border-radius: var(--radius); padding: 24rpx 28rpx; margin-right: 16rpx; min-width: 140rpx;
}
.service-icon { font-size: 48rpx; margin-bottom: 8rpx; }
.service-name { font-size: 26rpx; color: var(--text); }
.price { font-size: 30rpx; color: var(--danger); font-weight: 600; margin-top: 6rpx; }

.coupon-card { display: inline-flex; border-radius: var(--radius); overflow: hidden; margin-right: 16rpx; width: 320rpx; }
.coupon-left { background: var(--danger); color: #fff; padding: 20rpx 24rpx; flex: 1; }
.coupon-val { font-size: 44rpx; font-weight: 700; }
.coupon-name { font-size: 22rpx; display: block; margin-top: 4rpx; }
.coupon-right {
  background: #FFF1F0; color: var(--danger); padding: 20rpx 16rpx;
  font-size: 24rpx; display: flex; align-items: center; text-align: center;
}

.store-item { margin: 8rpx 24rpx; }
.store-icon {
  font-size: 48rpx; margin-right: 20rpx; width: 80rpx; height: 80rpx;
  background: #F0F5FF; border-radius: 50%; display: flex; align-items: center; justify-content: center;
}
.store-name { font-size: 30rpx; font-weight: 600; color: var(--text); display: block; }
.gray-text { font-size: 24rpx; color: var(--text-secondary); display: block; margin-top: 4rpx; }

.quick-book { margin: 32rpx 24rpx; background: var(--primary); height: 96rpx; }
.quick-book-text { color: #fff; font-size: 32rpx; font-weight: 600; }
