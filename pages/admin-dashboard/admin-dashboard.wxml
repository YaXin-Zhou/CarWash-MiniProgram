<view class="container">
  <navigation-bar title="管理面板"></navigation-bar>

  <view class="admin-header">
    <text class="admin-title">管理员</text>
    <text class="admin-date">今日数据概览</text>
  </view>

  <view class="stat-grid">
    <view class="stat-item">
      <text class="s-num">{{dashboard.todayOrders}}</text>
      <text class="s-label">今日订单</text>
    </view>
    <view class="stat-item">
      <text class="s-num">¥{{dashboard.todayRevenue}}</text>
      <text class="s-label">今日营收</text>
    </view>
    <view class="stat-item">
      <text class="s-num">{{dashboard.totalUsers}}</text>
      <text class="s-label">总用户</text>
    </view>
    <view class="stat-item">
      <text class="s-num">{{dashboard.totalServices}}</text>
      <text class="s-label">在售服务</text>
    </view>
  </view>

  <view class="card flex-between" bindtap="goToAdminOrders">
    <text class="card-label">全部订单管理</text>
    <text class="arrow">></text>
  </view>

  <view class="px-24">
    <text class="section-title">今日待处理订单</text>
  </view>

  <view class="order-list px-24">
    <view class="order-card card" wx:for="{{recentOrders}}" wx:key="id">
      <view class="flex-between">
        <view>
          <text class="o-no">{{item.order_no}}</text>
          <text class="o-user">{{item.nickname}}</text>
        </view>
        <view data-status="{{item.status}}" bindtap="updateStatus" data-id="{{item.id}}">
          <text class="o-status" style="color:{{util.getOrderStatusColor(item.status)}}">{{util.getOrderStatusText(item.status)}}</text>
        </view>
      </view>
      <view class="flex-between mt-16">
        <text class="o-service">{{item.service_name}} · {{item.store_name}}</text>
        <text class="o-amount">¥{{item.amount}}</text>
      </view>
      <text class="o-time">{{item.appoint_date}} {{item.appoint_time}}</text>

      <view class="o-actions flex" wx:if="{{item.status === 'pending'}}">
        <button class="btn-confirm" data-id="{{item.id}}" data-status="confirmed" bindtap="updateStatus">确认接单</button>
        <button class="btn-cancel" data-id="{{item.id}}" data-status="cancelled" bindtap="updateStatus">取消</button>
      </view>
      <view class="o-actions flex" wx:elif="{{item.status === 'confirmed'}}">
        <button class="btn-confirm" data-id="{{item.id}}" data-status="in_progress" bindtap="updateStatus">开始服务</button>
      </view>
      <view class="o-actions flex" wx:elif="{{item.status === 'in_progress'}}">
        <button class="btn-confirm" data-id="{{item.id}}" data-status="completed" bindtap="updateStatus">完成服务</button>
      </view>
    </view>

    <view wx:if="{{recentOrders.length === 0}}" class="empty-state">
      <text>暂无订单</text>
    </view>
  </view>
</view>
