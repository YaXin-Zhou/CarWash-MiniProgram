.avatar-area {
  padding: 48rpx 0 32rpx; flex-direction: column;
  background: linear-gradient(135deg, #1677FF, #69B1FF);
}
.avatar-box {
  width: 140rpx; height: 140rpx; border-radius: 50%; overflow: hidden;
  background: rgba(255,255,255,0.3); border: 4rpx solid rgba(255,255,255,0.5);
}
.avatar-box image { width: 100%; height: 100%; }
.avatar-placeholder { font-size: 70rpx; display: flex; align-items: center; justify-content: center; width: 100%; height: 100%; }
.avatar-tip { font-size: 24rpx; color: rgba(255,255,255,0.8); margin-top: 16rpx; }

.form { margin: 24rpx; }
.form-item {
  padding: 24rpx 0; border-bottom: 1rpx solid var(--border);
  display: flex; align-items: center;
}
.form-label { font-size: 28rpx; color: var(--text); width: 140rpx; flex-shrink: 0; }
.form-value { font-size: 28rpx; color: var(--text-muted); }
.form-input { font-size: 28rpx; flex: 1; text-align: right; }
